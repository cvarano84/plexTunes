# Genius API - Get yours at https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=your_genius_token_here

# Spotify API - Get yours at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Database - auto-configured by docker-compose, only change if using external DB
DATABASE_URL=postgresql://jukebox:jukebox@plextunes-db:5432/jukebox
