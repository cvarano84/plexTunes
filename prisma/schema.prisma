generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model PlexConfig {
  id        String   @id @default("default")
  serverUrl String
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CachedArtist {
  id            String         @id
  ratingKey     String         @unique
  name          String
  thumb         String?
  addedAt       Int?
  cachedTracks  CachedTrack[]
  cachedAlbums  CachedAlbum[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([name])
}

model CachedAlbum {
  id            String         @id
  ratingKey     String         @unique
  title         String
  year          Int?
  thumb         String?
  artistId      String
  artist        CachedArtist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre         String?
  cachedTracks  CachedTrack[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([artistId])
  @@index([year])
}

model CachedTrack {
  id              String        @id
  ratingKey       String        @unique
  title           String
  duration        Int?
  trackNumber     Int?
  year            Int?
  genre           String?
  artistId        String
  artist          CachedArtist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistName      String?
  albumId         String
  album           CachedAlbum   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  albumTitle      String?
  thumb           String?
  mediaKey        String?
  popularity      Int?
  spotifyChecked  Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([artistId])
  @@index([albumId])
  @@index([genre])
  @@index([year])
  @@index([popularity])
}

model Station {
  id          String   @id @default(cuid())
  name        String
  description String?
  decade      String?
  genre       String?
  imageUrl    String?
  trackCount  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([decade, genre])
}

model LibrarySyncStatus {
  id             String   @id @default("default")
  lastSyncAt     DateTime?
  totalArtists   Int      @default(0)
  totalAlbums    Int      @default(0)
  totalTracks    Int      @default(0)
  syncInProgress Boolean  @default(false)
  syncProgress   Int      @default(0)
  syncMessage    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
