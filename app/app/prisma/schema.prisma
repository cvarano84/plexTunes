generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/plex_jukebox/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Media server configuration - supports Plex, Jellyfin, and Subsonic (OpenSubsonic / Navidrome).
// Model name kept as `PlexConfig` to avoid a breaking schema migration; columns are
// repurposed across backends:
//   - serverType: "plex" | "jellyfin" | "subsonic"
//   - serverUrl:  base URL in every case
//   - token:      Plex token / Jellyfin API key / Subsonic password (kept server-side only)
//   - username:   Subsonic username (null for Plex/Jellyfin)
//   - libraryId:  the library section the user selected during setup (persisted so the
//                 sync/stream routes know which scope to target)
model PlexConfig {
  id         String   @id @default("default")
  serverType String   @default("plex")
  serverUrl  String
  token      String
  username   String?
  libraryId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CachedArtist {
  id            String         @id
  ratingKey     String         @unique
  name          String
  thumb         String?
  summary       String?
  addedAt       Int?
  cachedTracks  CachedTrack[]
  cachedAlbums  CachedAlbum[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([name])
}

model CachedAlbum {
  id            String         @id
  ratingKey     String         @unique
  title         String
  year          Int?
  thumb         String?
  artistId      String
  artist        CachedArtist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre         String?
  cachedTracks  CachedTrack[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([artistId])
  @@index([year])
}

model CachedTrack {
  id              String        @id
  ratingKey       String        @unique
  title           String
  duration        Int?
  trackNumber     Int?
  year            Int?
  genre           String?
  artistId        String
  artist          CachedArtist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistName      String?
  albumId         String
  album           CachedAlbum   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  albumTitle      String?
  thumb           String?
  mediaKey        String?
  popularity      Int?
  spotifyChecked  Boolean       @default(false)
  playCount       Int           @default(0)
  lastPlayedAt    DateTime?
  summary         String?
  billboardPeak   Int?
  billboardWeeks  Int?
  billboardCheckedAt DateTime?
  bpm             Float?
  bpmChecked      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([artistId])
  @@index([albumId])
  @@index([genre])
  @@index([year])
  @@index([popularity])
  @@index([playCount])
  @@index([billboardPeak])
}

model Station {
  id          String   @id @default(cuid())
  name        String
  description String?
  decade      String?
  genre       String?
  imageUrl    String?
  trackCount  Int      @default(0)
  isActive    Boolean  @default(true)
  stationType String   @default("standard")
  minPopularity Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([decade, genre])
}

model LibrarySyncStatus {
  id             String   @id @default("default")
  lastSyncAt     DateTime?
  totalArtists   Int      @default(0)
  totalAlbums    Int      @default(0)
  totalTracks    Int      @default(0)
  syncInProgress Boolean  @default(false)
  syncProgress   Int      @default(0)
  syncMessage    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model NowPlayingState {
  id        String   @id @default("default")
  state     String
  updatedAt DateTime @updatedAt
}

model RemoteAction {
  id        String   @id @default(cuid())
  type      String
  payload   String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model JukeboxSettings {
  id                  String   @id @default("default")
  idleTimeout         Int      @default(30)
  eqBands             Int      @default(32)
  eqColorScheme       String   @default("purple")
  previousTrackCount  Int      @default(3)
  keyboardSize        String   @default("xxl")
  columnLayout        String   @default("custom:30,45,25")
  artistRows          Int      @default(4)
  stationRows         Int      @default(3)
  lyricsZoom          Int      @default(3)
  jukeboxTitle        String   @default("")
  stationQueueSize    Int      @default(5)
  eqBarHeight         Int      @default(96)
  artistBioHeight     Int      @default(20)
  artistAlbumHeight   Int      @default(55)
  artistSimilarHeight Int      @default(25)
  artistTrackWidth    Int      @default(25)
  mixArtistIconSize   Int      @default(100)
  sweetFades          Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model Mix {
  id              String   @id @default(cuid())
  name            String
  stationIds      String[] @default([])
  artistIds       String[] @default([])
  popularOnly     Boolean  @default(true)
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// WLED panel / instance. Each entry represents one WLED controller on the LAN
// (e.g. a GL-C-010WL with two outputs).  For V1 we model the two outputs as a
// fixed "matrix" (scrolling now-playing text) and "perimeter" (ambient / audio
// reactive) slot - each mapping to a WLED segment id.
model WledInstance {
  id               String   @id @default(cuid())
  name             String
  host             String   // IP or hostname (no protocol / port)
  enabled          Boolean  @default(true)
  brightnessCap    Int      @default(200)

  // Output 1 - defaults to a 2D text matrix
  matrixEnabled    Boolean  @default(true)
  matrixSegmentId  Int      @default(0)
  matrixOutputType String   @default("matrix")     // "matrix" | "strip"
  matrixTextFormat String   @default("{title}")
  matrixColorMode  String   @default("fixed")      // "fixed" | "random"
  matrixColor      String   @default("#a855f7")
  matrixEffectId   Int      @default(165)          // WLED "Scrolling Text"
  matrixPaletteId  Int      @default(0)            // used when outputType=strip
  matrixSpeed      Int      @default(128)
  matrixIntensity  Int      @default(128)

  // Output 2 - defaults to an LED strip / perimeter
  perimeterEnabled    Boolean @default(true)
  perimeterSegmentId  Int     @default(1)
  perimeterOutputType String  @default("strip")    // "matrix" | "strip"
  perimeterTextFormat String  @default("{title}")
  perimeterColorMode  String  @default("fixed")    // "fixed" | "random"
  perimeterEffectId   Int     @default(0)          // Solid
  perimeterColor      String  @default("#a855f7")
  perimeterPaletteId  Int     @default(0)
  perimeterSpeed      Int     @default(128)
  perimeterIntensity  Int     @default(128)

  lastSeenAt      DateTime?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}